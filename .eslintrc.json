{
    "env": {
        "browser": true,
        "es2021": true,
        "serviceworker": true,
        "node": true
    },
    "extends": ["eslint:recommended", "prettier"],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "rules": {
        "no-console": "off",
        "quotes": ["error", "single"],
        "semi": ["error", "always"],
        "no-unused-vars": "warn"
    }
}
